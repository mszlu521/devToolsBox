{
  "name": "dev-tools-box",
  "version": "1.0.0",
  "description": "开发者工具箱 - 让开发更高效",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "build:mac": "vue-tsc --noEmit && vite build && electron-builder --mac",
    "build:linux": "vue-tsc --noEmit && vite build && electron-builder --linux",
    "build:all": "vue-tsc --noEmit && vite build && electron-builder --win --mac --linux",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "vue3",
    "environment",
    "path",
    "manager"
  ],
  "author": "EnvPath Manager",
  "license": "MIT",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "electron": "^40.8.0",
    "electron-builder": "^24.9.0",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.5",
    "typescript": "~5.8.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.16",
    "@element-plus/icons-vue": "^2.3.0",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-code-block-lowlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/extension-task-item": "^3.20.1",
    "@tiptap/extension-task-list": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/vue-3": "^3.20.1",
    "@types/highlight.js": "^10.1.0",
    "element-plus": "^2.5.0",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.7.2",
    "lowlight": "^3.3.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^17.0.4",
    "ping": "^1.0.0",
    "pinia": "^2.1.0",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6",
    "tiptap-markdown": "^0.9.0",
    "vditor": "^3.11.2",
    "vue-codemirror6": "^1.4.3",
    "vue-router": "^4.2.0"
  },
  "build": {
    "appId": "com.devtoolbox.app",
    "productName": "DevToolsBox",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "build/icon.png",
      "build/icon.ico"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "DevToolsBox",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "category": "public.app-category.utilities",
      "icon": "build/icon.png"
    },
    "linux": {
      "target": ["tar.gz", "deb", "AppImage"],
      "category": "Development",
      "maintainer": "DevToolsBox",
      "icon": "build/icon.png",
      "synopsis": "开发者工具箱",
      "description": "让开发更高效的工具集合"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
