{
  "name": "dev-tools-box",
  "version": "1.0.0",
  "description": "开发者工具箱 - 让开发更高效",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:win": "vue-tsc --noEmit && vite build && electron-builder --win",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "vue3",
    "environment",
    "path",
    "manager"
  ],
  "author": "EnvPath Manager",
  "license": "MIT",
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/tsconfig": "^0.5.0",
    "electron": "^40.8.0",
    "electron-builder": "^24.9.0",
    "typescript": "~5.8.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@types/highlight.js": "^10.1.0",
    "element-plus": "^2.5.0",
    "highlight.js": "^11.11.1",
    "iconv-lite": "^0.7.2",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-task-lists": "^2.1.1",
    "marked": "^17.0.4",
    "ping": "^1.0.0",
    "pinia": "^2.1.0",
    "vue-router": "^4.2.0"
  },
  "build": {
    "appId": "com.devtoolbox.app",
    "productName": "DevToolsBox",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  }
}
